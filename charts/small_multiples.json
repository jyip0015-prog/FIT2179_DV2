{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 430,
  "height": 320,
  "background": "transparent",

  "data": {
    "url": "data/ridership_headline.csv"
  },

  "transform": [
    {
      "fold": [
        "rail_lrt_ampang",
        "rail_lrt_kj",
        "rail_monorail",
        "rail_mrt_kajang"
      ],
      "as": ["Service", "Ridership"]
    },
    {
      "calculate": "toNumber(replace(datum.Ridership + '', /,/g, ''))",
      "as": "RidershipNumber"
    }
  ],

  "mark": {
    "type": "boxplot",
    "extent": "min-max",
    "size": 35
  },

  "encoding": {
    "y": {
      "field": "Service",
      "type": "nominal",
      "title": null,
      "sort": "-x"
    },
    "x": {
      "field": "RidershipNumber",
      "type": "quantitative",
      "title": "Daily Ridership"
    },
    "color": {
      "field": "Service",
      "type": "nominal",
      "legend": null,
      "scale": {
        "range": ["#2563eb", "#f97316", "#64748b", "#0ea5e9"]
      }
    },
    "tooltip": [
      {
        "field": "Service",
        "type": "nominal",
        "title": "Service"
      },
      {
        "field": "RidershipNumber",
        "type": "quantitative",
        "title": "Daily Ridership",
        "format": ","
      }
    ]
  },

  "config": {
    "axis": {
      "labelColor": "#374151",
      "titleColor": "#111827",
      "gridColor": "#e5e7eb",
      "domainColor": "#9ca3af",
      "tickColor": "#9ca3af"
    },
    "view": {
      "stroke": "transparent"
    }
  }
}