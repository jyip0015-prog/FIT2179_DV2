{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 900,
  "height": 420,
  "background": "transparent",

  "data": {
    "url": "data/ridership_headline.csv"
  },

  "params": [
    {
      "name": "SelectedService",
      "value": "rail_mrt_kajang",
      "bind": {
        "input": "select",
        "options": [
          "rail_mrt_kajang",
          "rail_lrt_kj",
          "rail_lrt_ampang",
          "rail_monorail",
          "rail_ets",
          "rail_komuter",
          "bus_rkl",
          "bus_rkn",
          "bus_rpn"
        ],
        "labels": [
          "MRT Kajang",
          "LRT Kelana Jaya",
          "LRT Ampang",
          "Monorail",
          "ETS",
          "Komuter",
          "Bus RKL",
          "Bus RKN",
          "Bus RPN"
        ],
        "name": "Choose service: "
      }
    }
  ],

  "transform": [
    {
      "fold": [
        "rail_mrt_kajang",
        "rail_lrt_kj",
        "rail_lrt_ampang",
        "rail_monorail",
        "rail_ets",
        "rail_komuter",
        "bus_rkl",
        "bus_rkn",
        "bus_rpn"
      ],
      "as": ["Service", "Ridership"]
    },
    {
      "filter": "datum.Service == SelectedService"
    },
    {
      "calculate": "toNumber(replace(datum.Ridership || '0', ',', ''))",
      "as": "RidershipNumber"
    }
  ],

  "mark": {
    "type": "area",
    "line": {
      "color": "#2563eb",
      "strokeWidth": 2
    },
    "color": {
      "x1": 1,
      "y1": 1,
      "x2": 1,
      "y2": 0,
      "gradient": "linear",
      "stops": [
        {
          "offset": 0,
          "color": "rgba(37, 99, 235, 0.05)"
        },
        {
          "offset": 1,
          "color": "rgba(37, 99, 235, 0.55)"
        }
      ]
    }
  },

  "encoding": {
    "x": {
      "field": "date",
      "type": "temporal",
      "title": "Date"
    },
    "y": {
      "field": "RidershipNumber",
      "type": "quantitative",
      "title": "Daily Ridership"
    },
    "tooltip": [
      {
        "field": "date",
        "type": "temporal",
        "title": "Date"
      },
      {
        "field": "Service",
        "type": "nominal",
        "title": "Service"
      },
      {
        "field": "RidershipNumber",
        "type": "quantitative",
        "title": "Ridership",
        "format": ","
      }
    ]
  },

  "config": {
    "axis": {
      "labelColor": "#374151",
      "titleColor": "#111827",
      "gridColor": "#e5e7eb",
      "domainColor": "#9ca3af",
      "tickColor": "#9ca3af"
    },
    "view": {
      "stroke": "transparent"
    }
  }
}