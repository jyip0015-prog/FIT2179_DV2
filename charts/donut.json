{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 360,
  "height": 320,
  "background": "transparent",

  "data": {
    "url": "data/ridership_headline.csv"
  },

  "transform": [
    {
      "calculate": "toNumber(replace(datum.bus_rkl + '', /,/g, '')) + toNumber(replace(datum.bus_rkn + '', /,/g, '')) + toNumber(replace(datum.bus_rpn + '', /,/g, ''))",
      "as": "Bus"
    },
    {
      "calculate": "toNumber(replace(datum.rail_lrt_ampang + '', /,/g, '')) + toNumber(replace(datum.rail_lrt_kj + '', /,/g, '')) + toNumber(replace(datum.rail_monorail + '', /,/g, '')) + toNumber(replace(datum.rail_mrt_kajang + '', /,/g, ''))",
      "as": "Rail"
    },
    {
      "fold": ["Bus", "Rail"],
      "as": ["Mode", "Ridership"]
    },
    {
      "aggregate": [
        {
          "op": "sum",
          "field": "Ridership",
          "as": "TotalRidership"
        }
      ],
      "groupby": ["Mode"]
    },
    {
      "calculate": "datum.Mode == 'Bus' ? 'Bus' : 'Rail'",
      "as": "TransportMode"
    }
  ],

  "mark": {
    "type": "arc",
    "innerRadius": 90,
    "outerRadius": 140,
    "cornerRadius": 6,
    "stroke": "#ffffff",
    "strokeWidth": 2
  },

  "encoding": {
    "theta": {
      "field": "TotalRidership",
      "type": "quantitative"
    },
    "color": {
      "field": "TransportMode",
      "type": "nominal",
      "title": "Mode",
      "scale": {
        "domain": ["Bus", "Rail"],
        "range": ["#2563eb", "#f97316"]
      },
      "legend": {
        "orient": "bottom",
        "direction": "horizontal",
        "title": "Transport Mode",
        "labelColor": "#334155",
        "titleColor": "#111827",
        "labelFontSize": 12,
        "titleFontSize": 13,
        "symbolSize": 140
      }
    },
    "tooltip": [
      {
        "field": "TransportMode",
        "type": "nominal",
        "title": "Mode"
      },
      {
        "field": "TotalRidership",
        "type": "quantitative",
        "title": "Total Ridership",
        "format": ","
      }
    ]
  },

  "config": {
    "legend": {
      "labelColor": "#334155",
      "titleColor": "#111827"
    },
    "view": {
      "stroke": "transparent"
    }
  }
}