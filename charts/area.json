{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 430,
  "height": 320,
  "background": "transparent",

  "data": {
    "url": "data/ridership_headline.csv"
  },

  "transform": [
    {
      "calculate": "year(toDate(datum.date))",
      "as": "Year"
    },
    {
      "calculate": "(isValid(datum.bus_rkl) ? toNumber(replace(datum.bus_rkl + '', /,/g, '')) : 0) + (isValid(datum.bus_rkn) ? toNumber(replace(datum.bus_rkn + '', /,/g, '')) : 0) + (isValid(datum.bus_rpn) ? toNumber(replace(datum.bus_rpn + '', /,/g, '')) : 0)",
      "as": "Bus"
    },
    {
      "calculate": "(isValid(datum.rail_lrt_ampang) ? toNumber(replace(datum.rail_lrt_ampang + '', /,/g, '')) : 0) + (isValid(datum.rail_lrt_kj) ? toNumber(replace(datum.rail_lrt_kj + '', /,/g, '')) : 0) + (isValid(datum.rail_mrt_kajang) ? toNumber(replace(datum.rail_mrt_kajang + '', /,/g, '')) : 0) + (isValid(datum.rail_monorail) ? toNumber(replace(datum.rail_monorail + '', /,/g, '')) : 0) + (isValid(datum.rail_ets) ? toNumber(replace(datum.rail_ets + '', /,/g, '')) : 0) + (isValid(datum.rail_komuter) ? toNumber(replace(datum.rail_komuter + '', /,/g, '')) : 0)",
      "as": "Rail"
    },
    {
      "fold": ["Bus", "Rail"],
      "as": ["Mode", "Ridership"]
    },
    
        {
      "filter": "datum.Year >= 2022"
    },

    {
      "aggregate": [
        {
          "op": "sum",
          "field": "Ridership",
          "as": "TotalRidership"
        }
      ],
      "groupby": ["Year", "Mode"]
    }
  ],

  "mark": {
    "type": "bar"
  },

  "encoding": {
    "x": {
      "field": "Year",
      "type": "ordinal",
      "title": "Year"
    },
    "y": {
      "field": "TotalRidership",
      "type": "quantitative",
      "stack": "normalize",
      "title": "Share of Annual Ridership",
      "axis": {
        "format": "%"
      }
    },
    "color": {
      "field": "Mode",
      "type": "nominal",
      "title": "Mode",
      "scale": {
        "domain": ["Bus", "Rail"],
        "range": ["#2563eb", "#f97316"]
      }
    },
    "tooltip": [
      {
        "field": "Year",
        "type": "ordinal",
        "title": "Year"
      },
      {
        "field": "Mode",
        "type": "nominal",
        "title": "Mode"
      },
      {
        "field": "TotalRidership",
        "type": "quantitative",
        "title": "Total Ridership",
        "format": ","
      }
    ]
  },

  "config": {
    "axis": {
      "labelColor": "#374151",
      "titleColor": "#111827",
      "gridColor": "#e5e7eb",
      "domainColor": "#9ca3af",
      "tickColor": "#9ca3af"
    },
    "legend": {
      "labelColor": "#374151",
      "titleColor": "#111827"
    },
    "view": {
      "stroke": "transparent"
    }
  }
}