{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 980,
  "height": 520,
  "background": "#f8fafc",

  "projection": {
    "type": "mercator",
    "center": [102.1, 4.1],
    "scale": 4300,
    "translate": [490, 270]
  },

  "layer": [
    {
      "data": {
        "url": "data/malaysia_states.geojson",
        "format": {
          "property": "features"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#dbeafe",
        "stroke": "#0f172a",
        "strokeWidth": 1.1,
        "opacity": 0.95
      }
    },
    {
      "data": {
        "url": "data/railways.geojson",
        "format": {
          "property": "features"
        }
      },
      "transform": [
        {
          "filter": "datum.geometry.type == 'LineString' || datum.geometry.type == 'MultiLineString'"
        }
      ],
      "mark": {
        "type": "geoshape",
        "filled": false,
        "stroke": "#2563eb",
        "strokeWidth": 2.5,
        "opacity": 0.95
      },
      "encoding": {
        "tooltip": [
          {
            "field": "properties.name",
            "type": "nominal",
            "title": "Railway Line"
          }
        ]
      }
    },
    {
      "data": {
        "url": "data/railways.geojson",
        "format": {
          "property": "features"
        }
      },
      "transform": [
        {
          "filter": "datum.geometry.type == 'Point'"
        }
      ],
      "mark": {
        "type": "circle",
        "size": 62,
        "color": "#f97316",
        "stroke": "#ffffff",
        "strokeWidth": 1.6,
        "opacity": 0.95
      },
      "encoding": {
        "longitude": {
          "field": "geometry.coordinates[0]",
          "type": "quantitative"
        },
        "latitude": {
          "field": "geometry.coordinates[1]",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "properties.name",
            "type": "nominal",
            "title": "Station"
          },
          {
            "field": "properties.railway",
            "type": "nominal",
            "title": "Type"
          }
        ]
      }
    }
  ],

  "config": {
    "view": {
      "stroke": "transparent"
    }
  }
}